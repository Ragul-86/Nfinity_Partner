NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (create a free cluster at mongodb.com/atlas)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nfinity_partner?retryWrites=true&w=majority

# Comma-separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# Used to sign JWTs if/when the admin panel (Phase 2) is enabled
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Email notifications for new leads (contact form + Growth Strategy Call
# submissions both go through this). SMTP_PASS is a Gmail App Password —
# set the real value only in your local .env, never commit it to GitHub.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=suganya.nfinitypartner@gmail.com
SMTP_PASS=${APP_PASSWORD}
LEAD_NOTIFICATION_EMAIL=suganya.nfinitypartner@gmail.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Shared secret required (as the x-internal-key header) to read/update leads
# until the Phase 2 admin panel with full JWT auth is built.
INTERNAL_API_KEY=replace-with-a-long-random-string
